- Grammar explanations must be extremely concise, clear, and easy to grasp for beginners.
- Always include comparison to similar grammar structures (So sánh cấu trúc tương đồng) to prevent common mistakes.
- Word-by-word breakdown must tag the exact HSK level (from HSK 1 to HSK 6).

Expected Output JSON Schema:
{
  "translation": "Dịch nghĩa tiếng Việt tự nhiên, mượt mà",
  "pinyin": "Phiên âm Pinyin toàn bộ câu",
  "vocabulary": [
    {
      "word": "Từ vựng (Chữ Hán)",
      "pinyin": "Phiên âm",
      "meaning": "Nghĩa tiếng Việt",
      "hsk": "Cấp độ HSK (1-6)"
    }
  ],
  "grammar_analysis": [
    {
      "point": "Tên cấu trúc ngữ pháp chính phát hiện trong câu",
      "explanation": "Giải thích ngắn gọn, dễ hiểu",
      "comparison": "So sánh với cấu trúc tương đồng hoặc lưu ý cách dùng dễ nhầm lẫn"
    }
  ]
}`;

                const endpoint = `https://generativelanguage.googleapis.com/v1beta/models/${GEMINI_MODEL}:generateContent?key=${GEMINI_API_KEY}`;
                
                const requestBody = {
                    contents: [
                        { parts: [{ text: `Phân tích câu này: "${normalized}"` }] }
                    ],
                    generationConfig: {
                        responseMimeType: "application/json"
                    },
                    systemInstruction: {
                        parts: [{ text: systemPrompt }]
                    }
                };

                const response = await fetch(endpoint, {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json"
                    },
                    body: JSON.stringify(requestBody)
                });

                if (!response.ok) {
                    throw new Error(`API returned status ${response.status}`);
                }

                const responseData = await response.json();
                
                // Parse text content from Gemini candidate
                const textResult = responseData.candidates?.[0]?.content?.parts?.[0]?.text;
                if (!textResult) {
                    throw new Error("No text candidates returned from model");
                }

                const cleanedJSON = cleanJSONString(textResult);
                const parsedData = JSON.parse(cleanedJSON);
                
                // Display results via API mode
                parsedData.chinese_original = normalized;
                displayResults(parsedData, "API");

            } catch (err) {
                console.warn("Gemini API call failed, transitioning seamlessly to offline database: ", err);
                // Fallback seamlessly: Search for matching parts or pick a highly related sentence from offline
                let fallbackData = null;
                let bestMatch = null;
                let maxCommonChars = -1;

                // Simple keyword/char matching to find the closest helper sentence
                for (const key of Object.keys(OFFLINE_DB)) {
                    let common = 0;
                    for (const char of normalized) {
                        if (key.includes(char)) {
                            common++;
                        }
                    }
                    if (common > maxCommonChars) {
                        maxCommonChars = common;
                        bestMatch = key;
                    }
                }

                // If no significant character overlap, fall back to the first sentence
                if (maxCommonChars > 0 && bestMatch) {
                    fallbackData = OFFLINE_DB[bestMatch];
                } else {
                    fallbackData = OFFLINE_DB["我喜欢学汉语。"]; // default
                }

                // Inject original query so user sees what they typed, but with helper offline tag
                const fallbackCopy = JSON.parse(JSON.stringify(fallbackData));
                fallbackCopy.chinese_original = normalized + ` (Phân tích tham khảo từ mẫu: "${bestMatch}")`;
                
                // Premium seamless display
                setTimeout(() => {
                    displayResults(fallbackCopy, "OFFLINE");
                }, 600);
            } finally {
                enableAnalyzeButton();
            }
        }

        function enableAnalyzeButton() {
            btnAnalyze.disabled = false;
            btnAnalyze.classList.remove("opacity-50", "cursor-not-allowed");
        }
    </script>

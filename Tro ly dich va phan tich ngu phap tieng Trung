                    <i data-lucide="bot" class="w-6 h-6 text-[#A24058] absolute"></i>
                </div>
                <h3 class="text-lg font-semibold text-[#201A1B] mb-1">Giảng Viên AI Đang Phân Tích...</h3>
                <p class="text-[#857376] text-sm max-w-sm mx-auto animate-pulse">Quá trình này bóc tách ngữ pháp, tra từ điển HSK và dịch nghĩa. Vui lòng đợi trong giây lát.</p>
            </div>

            <!-- Active Analysis Board Content -->
            <div id="board-results" class="hidden flex flex-col gap-6">
                
                <!-- Main Sentence and Translation -->
                <div class="bg-white rounded-[32px] shadow-[0_4px_24px_rgba(0,0,0,0.02)] border border-[#F5EEEE] overflow-hidden">
                    <div class="bg-[#FFF1F2] px-6 py-4 border-b border-[#F5EEEE] flex items-center justify-between">
                        <span class="text-xs font-bold text-[#A24058] uppercase tracking-wider flex items-center gap-1.5">
                            <i data-lucide="languages" class="w-3.5 h-3.5"></i> Kết quả dịch nghĩa
                        </span>
                        <span id="analysis-badge" class="text-xs bg-[#A24058] text-white font-semibold px-2.5 py-1 rounded-full shadow-sm">AI Phản hồi</span>
                    </div>
                    
                    <div class="p-6 md:p-8 flex flex-col gap-4">
                        <!-- Original sentence -->
                        <div class="text-center py-2">
                            <p id="result-pinyin" class="text-[#857376] font-mono text-xs md:text-sm tracking-widest mb-1 uppercase select-all"></p>
                            <h2 id="result-chinese" class="text-2xl md:text-3.5xl font-bold text-[#201A1B] tracking-normal select-all"></h2>
                        </div>
                        
                        <hr class="border-[#F5EEEE] my-2">

                        <!-- Vietnamese Translation -->
                        <div>
                            <span class="text-xs font-bold text-[#857376] uppercase tracking-wider block mb-1">Dịch Nghĩa Tiếng Việt</span>
                            <div class="bg-[#FDF8F9] border-l-4 border-[#A24058] rounded-r-xl p-4">
                                <p id="result-translation" class="text-[#201A1B] text-lg font-medium leading-relaxed"></p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Vocabulary Table Card -->
                <div class="bg-white rounded-[32px] shadow-[0_4px_24px_rgba(0,0,0,0.02)] border border-[#F5EEEE] p-5 md:p-6">
                    <div class="flex items-center justify-between mb-4">
                        <h3 class="text-md font-semibold text-[#201A1B] flex items-center gap-2">
                            <i data-lucide="book-open" class="w-5 h-5 text-[#A24058]"></i>
                            Phân Tích Chi Tiết Từ Vựng
                        </h3>
                        <span class="text-xs text-[#857376]">Chạm để xem kĩ</span>
                    </div>
                    
                    <div class="overflow-x-auto rounded-xl border border-[#F5EEEE]">
                        <table class="w-full text-left border-collapse">
                            <thead>
                                <tr class="bg-[#FDF8F9] text-[#857376] uppercase text-[10px] tracking-wider border-b border-[#F5EEEE]">
                                    <th class="py-3 px-4 font-bold">Từ vựng</th>
                                    <th class="py-3 px-4 font-bold">Phiên âm</th>
                                    <th class="py-3 px-4 font-bold">Ý nghĩa</th>
                                    <th class="py-3 px-4 font-bold text-center">HSK</th>
                                </tr>
                            </thead>
                            <tbody id="result-vocab-body" class="divide-y divide-[#F5EEEE] text-sm text-[#1D1B1E]">
                                <!-- Dynamic rows -->
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Grammar Analysis Section -->
                <div class="bg-white rounded-[32px] shadow-[0_4px_24px_rgba(0,0,0,0.02)] border border-[#F5EEEE] p-5 md:p-6">
                    <div class="flex items-center gap-2 mb-4">
                        <i data-lucide="git-branch" class="w-5 h-5 text-[#A24058]"></i>
                        <h3 class="text-md font-semibold text-[#201A1B]">Phân Tích Cú Pháp & Ngữ Pháp</h3>
                    </div>
                    
                    <div id="result-grammar-container" class="flex flex-col gap-4">
                        <!-- Dynamic grammar cards -->
                    </div>
                </div>

            </div>

        </section>

    </main>

    <!-- Footer -->
    <footer class="bg-[#FFF8F7] text-[#857376] border-t border-[#F5EEEE] py-6 text-center text-xs mt-auto">
        <div class="max-w-6xl mx-auto px-4 flex flex-col sm:flex-row items-center justify-between gap-4">
            <p>© 2026 Trợ Lý Dịch & Phân Tích Cú Pháp Tiếng Trung HSK. Thiết kế cho cộng đồng tự học tiếng Trung.</p>
            <div class="flex items-center gap-4">
                <span class="hover:text-[#A24058] transition-colors duration-200">Phiên bản 2.5</span>
                <span class="text-[#F5EEEE]">|</span>
                <span class="hover:text-[#A24058] transition-colors duration-200 flex items-center gap-1">
                    <i data-lucide="shield" class="w-3.5 h-3.5 text-[#A24058]"></i> Dữ liệu bảo mật
                </span>
            </div>
        </div>
    </footer>


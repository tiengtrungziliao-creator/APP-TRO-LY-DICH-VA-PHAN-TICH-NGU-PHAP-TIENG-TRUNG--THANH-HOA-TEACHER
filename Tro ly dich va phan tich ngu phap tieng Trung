                        <i data-lucide="activity" class="w-4 h-4"></i>
                        <span>Bắt đầu Phân Tích</span>
                    </button>
                </div>
            </div>

            <!-- Example Quick-Buttons -->
            <div class="bg-white rounded-[32px] shadow-[0_4px_24px_rgba(0,0,0,0.02)] border border-[#F5EEEE] p-5 md:p-6">
                <div class="flex items-center gap-2 mb-4">
                    <i data-lucide="library" class="w-5 h-5 text-[#A24058]"></i>
                    <h2 class="text-md font-semibold text-[#201A1B]">Mẫu Câu Kinh Điển (HSK 1 - 5)</h2>
                </div>
                
                <div class="flex flex-col gap-4">
